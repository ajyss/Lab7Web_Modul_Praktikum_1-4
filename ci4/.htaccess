<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /lab11_ci/ci4/
    
    # IMPORTANT: You may need to uncomment the following line for some hosts
    # RewriteBase /lab11_ci/ci4/
    
    # Redirect requests to the public folder
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
